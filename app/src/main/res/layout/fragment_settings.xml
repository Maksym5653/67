<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- API Key card -->
        <LinearLayout android:id="@+id/card_key"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="16dp"
            android:orientation="vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// GEMINI API KEY" android:textColor="@color/accent_red"
                android:textSize="11sp" android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tv_key_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:fontFamily="monospace"
                android:layout_marginBottom="10dp"/>
            <EditText android:id="@+id/et_api_key"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_input" android:textColor="@color/accent_red"
                android:textColorHint="@color/text_hint" android:hint="AIzaSy..."
                android:textSize="12sp" android:fontFamily="monospace"
                android:inputType="textPassword" android:padding="12dp"
                android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btn_save_key"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="[ ЗБЕРЕГТИ КЛЮЧ ]"
                android:background="@drawable/bg_btn_secondary"
                android:textColor="@color/accent_red" android:textSize="13sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Tap mode card -->
        <LinearLayout android:id="@+id/card_tap"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="16dp"
            android:orientation="vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// РЕЖИМ ТОРКАННЯ" android:textColor="@color/accent_red"
                android:textSize="11sp" android:fontFamily="monospace"
                android:layout_marginBottom="12dp"/>
            <RadioGroup android:id="@+id/rg_tap_mode"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <RadioButton android:id="@+id/rb_single"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="ОДНЕ ТОРКАННЯ — аналіз екрану"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:fontFamily="monospace" android:buttonTint="@color/accent_red"
                    android:layout_marginBottom="8dp"/>
                <RadioButton android:id="@+id/rb_double"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="ПОДВІЙНЕ ТОРКАННЯ — аналіз (одне = сховати)"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:fontFamily="monospace" android:buttonTint="@color/accent_red"/>
            </RadioGroup>
        </LinearLayout>

        <!-- Account card -->
        <LinearLayout android:id="@+id/card_account"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="16dp"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// АКАУНТ" android:textColor="@color/accent_red"
                android:textSize="11sp" android:fontFamily="monospace"
                android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/tv_current_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="13sp"
                android:fontFamily="monospace" android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Скинути ім'я (перезайти)"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <Switch android:id="@+id/switch_reset_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="@color/accent_red" android:trackTint="#33FF3333"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>