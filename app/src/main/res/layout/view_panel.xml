<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_panel"
    android:elevation="20dp">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="50dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="14dp" android:paddingEnd="4dp"
        android:background="@drawable/bg_panel_header">
        <View android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/bg_dot_red" android:layout_marginEnd="10dp"/>
        <TextView android:id="@+id/tv_panel_name"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="MW AI"
            android:textColor="#FFFFFF" android:textSize="13sp"
            android:textStyle="bold" android:fontFamily="monospace"/>
        <ImageButton android:id="@+id/btn_refresh"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/bg_icon_btn"
            android:tint="@color/text_secondary"/>
        <ImageButton android:id="@+id/btn_close"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/bg_icon_btn"
            android:tint="@color/text_secondary" android:layout_marginStart="2dp"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progress_bar"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true" android:indeterminateTint="@color/accent_red"
        android:visibility="gone"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:maxHeight="300dp">
        <TextView android:id="@+id/tv_content"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="14dp" android:textColor="@color/text_primary"
            android:textSize="14sp" android:lineSpacingMultiplier="1.5"
            android:fontFamily="monospace"/>
    </ScrollView>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="[✕] закрити  [✕✕] сховати  [🔄] новий аналіз"
        android:textColor="@color/text_hint" android:textSize="10sp"
        android:gravity="center" android:fontFamily="monospace"
        android:paddingTop="6dp" android:paddingBottom="8dp"/>
</LinearLayout>