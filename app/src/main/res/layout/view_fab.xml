<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="72dp" android:layout_height="72dp">
    <View android:id="@+id/fab_glow"
        android:layout_width="72dp" android:layout_height="72dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_fab_glow" android:alpha="0.7"/>
    <LinearLayout
        android:layout_width="58dp" android:layout_height="58dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_fab"
        android:orientation="vertical" android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MW" android:textColor="#FFFFFF" android:textSize="15sp"
            android:textStyle="bold" android:fontFamily="monospace"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AI" android:textColor="#FF6B6B" android:textSize="10sp"
            android:textStyle="bold" android:fontFamily="monospace"/>
    </LinearLayout>
</FrameLayout>