<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient android:startColor="#B71C1C" android:endColor="#7B0000" android:angle="135"/>
            <stroke android:width="2dp" android:color="#FF6B6B"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:startColor="#E53935" android:endColor="#1A0000" android:angle="135"/>
            <stroke android:width="2dp" android:color="#E53935"/>
        </shape>
    </item>
</selector>